# --- Transcription (STT) ---
VOXTRAL_API_KEY=your_voxtral_api_key_here

# --- Moteur de generation (LLM) ---
# Fournisseur actif : mistral (defaut, souverain) ou anthropic.
LLM_PROVIDER=mistral
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-large-latest
# Necessaire uniquement si LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# --- Moteur de compte-rendu ---
# local (defaut : Voxtral + LLM) ou gilbert (moteur distant Lexia, cf. docs/INTEGRATION_GILBERT.md)
REPORT_ENGINE=local
GILBERT_API_KEY=

# --- Base de donnees ---
DATABASE_URL=postgresql+asyncpg://anapath:anapath_dev@localhost:5432/anapath

# --- Securite ---
JWT_SECRET=generate-a-random-32-char-secret-here
CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# --- Divers ---
MAX_UPLOAD_SIZE_MB=200
